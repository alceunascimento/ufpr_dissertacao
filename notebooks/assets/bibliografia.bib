@article{zaparolliDominanciaFiscalPremio2024,
  title = {{Domin\^ancia fiscal e pr\^emio de risco no Brasil}},
  author = {Zaparolli, Marcio Jos{\'e} Szpaki and Fernandes, Carl{\^a}ndia Brito Santos},
  year = 2024,
  month = jan,
  journal = {Estudios econ\'omicos},
  volume = {41},
  number = {82},
  pages = {189--221},
  publisher = {Universidad Nacional del Sur},
  address = {Bah\'ia Blanca},
  issn = {2525-1295, 0425-368X},
  doi = {10.52292/j.estudecon.2024.3022},
  url = {https://revistas.uns.edu.ar/ee/article/view/3022},
  urldate = {2026-04-16},
  abstract = {The aim of this paper was to verify whether the Brazilian economy was under fiscal dominance in the years 2015 and 2016, during the period of the downgrade of Brazil's rating and the presidential impeachment process. We applied the model proposed by Blanchard (2004), studying the effect of an increase in domestic interest rate on the exchange one. The empirical analysis considered the movements in the capital flow and risk premium derived from the greater public indebtedness expectation. The results show that the increase causes a movement contrary to what was expected, depreciating the exchange rate given the relationship between the expected public debt and the probability of default, jeopardizing the inflationary control and confirming the fiscal dominance hypothesis.},
  copyright = {http://creativecommons.org/licenses/by-nc/4.0},
  langid = {portuguese},
  file = {C:\Users\alceu\Zotero\storage\DFP6R4RL\Szpaki Zaparolli and Santos Fernandes - 2024 - Dominância fiscal e prêmio de risco no Brasil.pdf}
}
