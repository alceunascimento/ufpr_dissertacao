@phdthesis{latifREGIMEMONETARIONO1995,
  type = {{disserta\c c\~ao de mestrado}},
  title = {{Regime monet\'ario no Brasil e descontrole inflacion\'ario}},
  author = {Latif, Zeina Abdel},
  year = 1995,
  address = {S\~ao Paulo},
  abstract = {O ponto central do trabalho \'e, a partir da caracteriza\c c\~ao do regime monet\'ario, explicar a din\^amica inflacion\'aria na economia brasileira. A caracteriza\c c\~ao completa do regime monet\'ario pressup\~oe a identifica\c c\~ao: do arranjo institucional distorcivo entre a Autoridade Monet\'aria e a Autoridade Fiscal; da instabilidade do regime fiscal; do regime de indexa\c c\~ao cambial; do instrumento de pol\'itica econ\^omica utilizado, no caso a taxa de juros; e da indexa\c c\~ao generalizada da economia. Todos aqueles fatores conjuntamente explicam um processo inflacion\'ario caracterizado por elevadas taxas de infla\c c\~ao que convergem, possivelmente, ainda que lentamente, para um processo hiperinflacion\'ario. \'E o chamado processo de megainfla\c c\~ao. A conclus\~ao principal \'e que, apesar da causa inicial da infla\c c\~ao serem os desequil\'ibrios fiscais verificados, principalmente, na d\'ecada de setenta, a din\^amica inflacion\'aria \'e explicada pelo regime monet\'ario inst\'avel, conforme caracterizado pelos pontos acima citados.},
  langid = {portuguese},
  school = {Universidade de S\~ao Paulo},
  file = {C:\Users\alceu\Zotero\storage\F4K5F97K\Latif - REGIME MONETÁRIO NO BRASIL E DESCONTROLE INFLACIONÁRIO.pdf}
}

@techreport{mishkinCanInflationTargeting2004,
  type = {Working {{Paper}}},
  title = {Can Inflation Targeting Work in Emerging Market Countries?},
  author = {Mishkin, Frederic S},
  year = 2004,
  month = jul,
  number = {10646},
  pages = {36},
  address = {Cambridge},
  institution = {National Bureau of Economic Research},
  abstract = {This paper explores issues in emerging market countries to make inflation targeting work for them. It starts by outlining why emerging market economies are so different from advanced economies and then discuss why developing strong fiscal, financial and monetary institutions is so critical to the success of inflation targeting in emerging market countries. Then it discusses two emerging market countries which illustrate what it takes to make inflation targeting work well, Chile and Brazil. It then addresses a particularly complicated issue for central banks in emerging market countries who engage in inflation targeting: how they deal with exchange rate fluctuations. The next topic focuses on the IMF's role in promoting the success of inflation targeting in emerging market countries. The conclusion from this analysis is that inflation targeting is more complicated in emerging market countries and is thus not a panacea. However, inflation targeting done right can be a powerful tool to help promote macroeconomic stability in these countries.},
  langid = {english},
  file = {C:\Users\alceu\Zotero\storage\INICXZMT\Mishkin - NBER WORKING PAPER SERIES.pdf}
}

